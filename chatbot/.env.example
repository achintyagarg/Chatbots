# --- Gemini model access ---
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE

# Defaults to gemini-flash-lite-latest, which has a workable free-tier quota.
# gemini-3.5-flash gives better answers but its free daily cap is low enough
# that a few dozen turns exhaust it.
CHATBOT_MODEL=gemini-flash-lite-latest

# --- GitHub MCP access (read path) ---
# Create a token at https://github.com/settings/tokens
# The MCP toolset is read-only, so a classic token with "public_repo" scope
# (or a fine-grained token with read-only Contents/Issues/Metadata) is enough
# unless you enable writes below.
GITHUB_PERSONAL_ACCESS_TOKEN=PASTE_YOUR_GITHUB_PAT_HERE

# --- Write policy (SafetyPlugin enforces this before any human is asked) ---
# Comma-separated "owner/repo" entries the agent may write to. Empty means no
# writes are permitted at all, which is the safe default -- leave it empty
# unless you actually want the agent opening issues and posting comments.
# Writing also needs a token with write scope, which the read-only setup above
# does not have.
GITHUB_WRITE_ALLOWLIST=

# --- Retrieval ---
# Where the Chroma index lives. Defaults to ./.chroma
# CHROMA_PATH=./.chroma
#
# Minimum cosine similarity for a corpus hit to count. Calibrated at 0.60 for
# gemini-embedding-001 at 768 dimensions; see tools/corpus.py before changing.
# CORPUS_MIN_SIMILARITY=0.60

# --- Server ---
# SESSION_DB_URI=sqlite:///./sessions.db
# LOG_LEVEL=INFO
# ALLOW_CORS=1

# --- Repo the grounding comparison script targets ---
DEMO_REPO_OWNER=google
DEMO_REPO_NAME=adk-python
